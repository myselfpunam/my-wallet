# =============================================================================
#  My Wallet — Environment Configuration
#  Copy this file to  .env  and fill in your values.
#  NEVER commit the real  .env  to version control.
# =============================================================================

# ── Core Django ───────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1


# ── Email / SMTP ─────────────────────────────────────────────────────────────
#
# Option A — Development (prints emails to the terminal, no SMTP needed)
#
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Option B — Gmail SMTP (recommended for production)
#
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to  https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail" → copy the 16-char code.
#   4. Paste it as EMAIL_HOST_PASSWORD below (no spaces).
#
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=myselfpunam.bhuiyan@gmail.com
EMAIL_HOST_PASSWORD=txgwumywhujsmjnp
DEFAULT_FROM_EMAIL=My Wallet <myselfpunam.bhuiyan@gmail.com>
EMAIL_TIMEOUT=10

#
# Other providers:
#
#   Outlook / Hotmail
#     EMAIL_HOST=smtp-mail.outlook.com
#     EMAIL_PORT=587
#
#   Yahoo Mail
#     EMAIL_HOST=smtp.mail.yahoo.com
#     EMAIL_PORT=587
#
#   SendGrid (transactional / high volume)
#     EMAIL_HOST=smtp.sendgrid.net
#     EMAIL_PORT=587
#     EMAIL_HOST_USER=apikey
#     EMAIL_HOST_PASSWORD=<your SendGrid API key>
#


# ── OTP Settings ─────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10   # How long an OTP is valid
OTP_MAX_ATTEMPTS=5      # Wrong guesses before OTP is invalidated
OTP_MAX_RESENDS=3       # Maximum resend requests per registration/reset


# ── Database (leave as-is for SQLite) ────────────────────────────────────────
# For PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/fintrack
